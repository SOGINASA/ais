# Flask
FLASK_ENV=development
APP_NAME=MyApp
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here

# Database (defaults to SQLite in ./database/database.db)
DATABASE_URL=sqlite:///database/database.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL (used for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/oauth/callback/google

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5000/api/auth/oauth/callback/github

# OAuth — Telegram Login Widget
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# WebAuthn (biometric auth)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=MyApp
WEBAUTHN_ORIGIN=http://localhost:3000

# Web Push (VAPID) — generate with: flask generate-vapid
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@example.com

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
